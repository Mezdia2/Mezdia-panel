{
  "name": "mezdia-deploy-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Telegram bot that provisions and manages Mezdia Panel workers across a user's Cloudflare accounts.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "kv:create": "wrangler kv namespace create BOT_DB",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "vitest": "^2.1.9",
    "wrangler": "^4.107.1"
  }
}
